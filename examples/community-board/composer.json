{
    "name": "blackops/community-board-example",
    "description": "Full-stack BlackOps community board reference application.",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../..",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.5",
        "blackops/framework": "dev-main",
        "doctrine/dbal": "^4.4",
        "doctrine/migrations": "^3.9",
        "vlucas/phpdotenv": "^5.6",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "symfony/uid": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "13.2.2"
    },
    "config": {
        "sort-packages": true
    }
}
