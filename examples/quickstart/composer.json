{
    "name": "blackops/skeleton",
    "description": "Feature-first BlackOps application skeleton.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "blackops/framework": "^1.1",
        "vlucas/phpdotenv": "^5.6",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "laminas/laminas-httphandlerrunner": "^2.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-create-project-cmd": "@php bin/setup"
    }
}
