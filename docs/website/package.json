{
  "name": "@blackops/docs-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "content:generate": "node scripts/generate-content.mjs",
    "content:check": "node scripts/check-content.mjs",
    "site:check": "node scripts/check-site.mjs",
    "test": "node --test --test-isolation=none tests/*.test.mjs",
    "astro:check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "check": "pnpm run content:check && pnpm run astro:check",
    "build": "pnpm run content:generate && ASTRO_TELEMETRY_DISABLED=1 astro build && node scripts/check-artifact.mjs && pnpm run site:check",
    "dev": "pnpm run content:generate && ASTRO_TELEMETRY_DISABLED=1 astro dev"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.3",
    "astro": "7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3"
  }
}
