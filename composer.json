{
    "name": "blackops/framework",
    "description": "BlackOps PHP Framework.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0",
        "psr/clock": "^1.0",
        "nyholm/psr7": "^1.8",
        "nikic/fast-route": "^1.3",
        "symfony/uid": "^7.4",
        "symfony/console": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/config": "^7.4",
        "monolog/monolog": "^3.10",
        "doctrine/dbal": "^4.4",
        "doctrine/migrations": "^3.9",
        "symfony/stopwatch": "^7.4"
    },
    "require-dev": {
        "carthage-software/mago": "1.42.0",
        "phpunit/phpunit": "13.2.2",
        "deptrac/deptrac": "4.6.2"
    },
    "autoload": {
        "psr-4": {
            "BlackOps\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlackOps\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "carthage-software/mago-composer-plugin": true
        }
    }
}
